# Include only specific file types
recursive-include ovo *

prune **/test-results

prune **/node_modules

prune ovo/pipelines/*/local

prune ovo/app/components/*/test_files

# Patterns to exclude from any directory
global-exclude *~
global-exclude *.pyc
global-exclude *.pyo
global-exclude .git
global-exclude .DS_Store
global-exclude .ipynb_checkpoints
global-exclude *.map
