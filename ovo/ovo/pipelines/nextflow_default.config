import nextflow.util.PathTrie

timeline.overwrite = true
dag.overwrite = true
report.overwrite = true
trace.overwrite = true

params {
    shared_modules = null
    publish_dir = null
    docker_repository = ""
    ovo_container_dir = "https://ovo.dichlab.org/public/singularity"

    getModulePath = (String moduleName) -> {
        if (params.shared_modules == null) {
            throw new RuntimeException("Please use --shared_modules ovo:/path/to/ovo,ovo_plugin:/path/to/ovo_plugin with paths to ovo and ovo plugins when running this nextflow pipeline directly.")
        }
        def modulePaths = params.shared_modules.split(",").collectEntries {
            def (name, path) = it.split(":", 2)
            [(name): path]
        }
        if (!modulePaths.containsKey(moduleName)) {
            throw new RuntimeException("Module name '${moduleName}' not found in shared_modules: ${params.shared_modules}")
        }
        return modulePaths[moduleName]
    }

	getSharedPipelinePath = (String pipelineName) -> {
        // Get path to ovo pipeline directory using pipelineName in format module_name.pipeline_name
        // For example ovo.my_pipeline or ovo_plugin.other_pipeline
        // This function should be overriden in implementations like HealthOmics
        def moduleName = "ovo"
        if (pipelineName.contains(".")) {
            def parts = pipelineName.split("\\.", 2)
            moduleName = parts[0]
            pipelineName = parts[1]
        }
        return "${params.getModulePath(moduleName)}/pipelines/${pipelineName}"
    }

    getSharedEnv = (String envName, String profile) -> {
        // Get path to ovo environment file using environment name
        def moduleName = "ovo"
        if (envName.contains(".")) {
            def parts = envName.split("\\.", 2)
            moduleName = parts[0]
            envName = parts[1]
        }
        def modulePath = params.getModulePath(moduleName)
        def cpuEnv = "${modulePath}/envs/${envName}.cpu.yml"
        def env = "${modulePath}/envs/${envName}.yml"
        if (profile.tokenize(",").contains("cpu_env") && new File(cpuEnv).exists()) {
            return cpuEnv
        } else {
            return env
        }
    }

    shared_mount_paths = []
    if (params.shared_modules != null) {
        final trie = new PathTrie()
        params.shared_modules.split(",").each {
            def (name, path) = it.split(":", 2)
            trie.add(path)
        }
        shared_mount_paths = trie.longest()
    }
}

profiles {
    conda {
        conda.enabled = true
    }
    mamba {
        mamba.enabled = true
    }
    docker {
        docker.enabled = true
        process {
            containerOptions = "" + params.shared_mount_paths.collect { path -> " -v ${path}:${path} " }.join(" ")
        }
    }
    podman {
        podman.enabled = true
        process {
            containerOptions = "" + params.shared_mount_paths.collect { path -> " -v ${path}:${path} " }.join(" ")
        }
    }
    singularity {
        singularity.enabled = true
        singularity.pullTimeout = "120m"
        process {
            containerOptions = "--nv " \
              + "--env TRITON_CACHE_DIR=/tmp --env XDG_CACHE_HOME=/tmp --env NUMBA_CACHE_DIR=/tmp " \
              + params.shared_mount_paths.collect { path -> " -B ${path}:${path} " }.join(" ")
        }
    }
    apptainer {
        apptainer.enabled = true
        apptainer.pullTimeout = "120m"
        process {
            containerOptions = "--nv " \
              + "--env TRITON_CACHE_DIR=/tmp --env XDG_CACHE_HOME=/tmp --env NUMBA_CACHE_DIR=/tmp " \
              + params.shared_mount_paths.collect { path -> " -B ${path}:${path} " }.join(" ")
        }
    }
    cpu_env {
        // Profile to use CPU-only conda or docker environment
    }
}
