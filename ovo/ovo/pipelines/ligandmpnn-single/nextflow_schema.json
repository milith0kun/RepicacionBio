{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com///nextflow_schema.json",
  "title": "LigandMPNN single pdb",
  "description": "",
  "type": "object",
  "required": [
    "pdb_path"
  ],
  "properties": {
    "pdb_path": {
      "type": "string",
      "description": "Input PDB file path for LigandMPNN"
    },
    "number_of_batches": {
      "type": "string",
      "description": "Number of times to design sequence using a chosen batch size"
    },
    "run_parameters": {
      "type": "string",
      "description": "Additional CLI arguments for LigandMPNN"
    },
    "helpfull": {
      "type": "boolean",
      "description": "Show full help message"
    },
    "publish_dir": {
      "type": "string"
    },
    "docker_repository": {
      "type": "string"
    }
  }
}
